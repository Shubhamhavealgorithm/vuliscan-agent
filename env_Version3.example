# OpenAI-compatible API settings (works with OpenAI, Azure OpenAI, or other compatible gateways)
BASE_URL=https://api.openai.com/v1
API_KEY=your_key_here
MODEL=gpt-4.1-mini

# Reproducibility
TEMPERATURE=0.2
MAX_TOKENS=1600

# Optional baseline runner (Anthropic) - only needed if you choose API baseline
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest